# Normalizar todos los archivos de texto a LF en el repositorio
* text=auto eol=lf

# Forzar LF en archivos de código
*.ts   text eol=lf
*.tsx  text eol=lf
*.js   text eol=lf
*.jsx  text eol=lf
*.json text eol=lf
*.md   text eol=lf
*.yml  text eol=lf
*.yaml text eol=lf
*.prisma text eol=lf
*.toml text eol=lf
*.sql  text eol=lf
*.env.example text eol=lf
.gitignore text eol=lf
.gitattributes text eol=lf

# Archivos binarios (no modificar)
*.png  binary
*.jpg  binary
*.jpeg binary
*.gif  binary
*.ico  binary
*.webp binary
*.p8   binary
*.p12  binary
*.jks  binary
*.mobileprovision binary
