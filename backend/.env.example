# Copiar este archivo como `.env` y completar los valores reales.
# NUNCA subir el `.env` al repositorio.

# ─── Base de datos (SQL Server) ───────────────────────────────────────────────
# Formato: sqlserver://HOST:PUERTO;database=NOMBRE_DB;user=USUARIO;password=CONTRASEÑA;encrypt=true;trustServerCertificate=true
# Docker (database/docker-compose.yml): SA_PASSWORD por defecto YourStrong!Pass123 — en esta URL el ! va codificado como %21:
# password=YourStrong%21Pass123
# P1000 / "credentials not valid" suele ser olvidar el %21 o clave distinta a la del contenedor (ver SETUP.md).
DATABASE_URL="sqlserver://localhost:1433;database=restaurant_db;user=sa;password=YourStrong%21Pass123;encrypt=true;trustServerCertificate=true"

# ─── JWT ──────────────────────────────────────────────────────────────────────
# Secreto para firmar tokens. Usar al menos 32 caracteres aleatorios en producción.
JWT_SECRET="cambia-esto-por-un-secreto-seguro-de-al-menos-32-chars"

# ─── Servidor ─────────────────────────────────────────────────────────────────
PORT=3000
NODE_ENV=development

# ─── CORS ─────────────────────────────────────────────────────────────────────
# Vacío en el flujo mínimo de SETUP.md. Si CORS molesta con Expo web, probá:
# CLIENT_URL="http://localhost:8081"
CLIENT_URL=
